{
  "manifest_version": 3,
  "name": "NASA Worldview Color-Temperature Table",
  "version": "1.0.0",
  "description": "Click on any palette layer in NASA Worldview to see a full color-to-Kelvin temperature correspondence table.",
  "permissions": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NASA Worldview Color-Temperature Table"
  },
  "content_scripts": [
    {
      "matches": [
        "*://worldview.earthdata.nasa.gov/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
